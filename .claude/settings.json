{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.key)",
      "Read(./.ssh/**)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(sudo *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(docker run *)",
      "Bash(npm publish *)"
    ],
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git pull *)",
      "Bash(git log *)",
      "Bash(python *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(npx *)",
      "Bash(node *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python common/scripts/md_to_docx.py \"${CLAUDE_TOOL_INPUT_PATH}\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python common/scripts/notify.py \"作業が完了しました\""
          }
        ]
      }
    ]
  }
}